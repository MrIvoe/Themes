{
  "button": {
    "bg": "accent.primary",
    "text": "text.inverse",
    "border": "border.default",
    "hover": "state.hover"
  },
  "input": {
    "bg": "surface.card",
    "text": "text.primary",
    "placeholder": "text.muted",
    "border": "border.default",
    "focus": "state.focus"
  },
  "editor": {
    "bg": "background.primary",
    "fg": "text.primary",
    "lineNumber": "text.muted",
    "cursor": "accent.primary",
