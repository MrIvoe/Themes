{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/MrIvoe/Themes/schema/theme.schema.json",
  "title": "Universal Theme Tokens",
  "type": "object",
  "required": ["meta", "tokens"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["id", "name", "version", "mode"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "mode": {
          "type": "string",
          "enum": ["light", "dark"]
        }
      },
      "additionalProperties": true
    },
    "tokens": {
      "type": "object",
      "required": ["background", "surface", "text", "accent", "border", "state", "syntax"],
      "properties": {
        "background": { "$ref": "#/$defs/tokenGroup" },
        "surface": { "$ref": "#/$defs/tokenGroup" },
        "text": { "$ref": "#/$defs/tokenGroup" },
        "accent": { "$ref": "#/$defs/tokenGroup" },
        "border": { "$ref": "#/$defs/tokenGroup" },
        "state": { "$ref": "#/$defs/tokenGroup" },
        "syntax": { "$ref": "#/$defs/tokenGroup" }
      },
      "additionalProperties": {
        "$ref": "#/$defs/tokenGroup"
      }
    }
  },
  "$defs": {
    "tokenGroup": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_]*$"
      },
      "additionalProperties": {
        "type": "string",
        "pattern": "^#(?:[A-Fa-f0-9]{6}|[A-Fa-f0-9]{8})$"
      }
    }
  },
  "additionalProperties": false
}
