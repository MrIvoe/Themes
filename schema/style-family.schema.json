{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/MrIvoe/Themes/schema/style-family.schema.json",
  "title": "Style Family Metadata",
  "description": "Schema for style family support levels and DNA metadata used by theme resources and references.",
  "type": "object",
  "required": ["meta", "families"],
  "additionalProperties": false,
  "properties": {
    "meta": {
      "type": "object",
      "required": ["version", "description"],
      "additionalProperties": true,
      "properties": {
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "families": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/family"
      }
    }
  },
  "$defs": {
    "family": {
      "type": "object",
      "required": ["label", "status", "supportedComponents", "fallbackFamily", "dna"],
      "additionalProperties": true,
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": ["stable", "partial", "experimental", "planned"]
        },
        "supportedComponents": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "fallbackFamily": {
          "type": "string",
          "minLength": 1
        },
        "dna": {
          "$ref": "#/$defs/dna"
        }
      }
    },
    "dna": {
      "type": "object",
      "required": [
        "mood",
        "shapeLanguage",
        "density",
        "motionCharacter",
        "glowUsage",
        "surfaceStyle",
        "accentStrategy"
      ],
      "additionalProperties": false,
      "properties": {
        "mood": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "shapeLanguage": {
          "type": "string",
          "minLength": 1
        },
        "density": {
          "type": "string",
          "minLength": 1
        },
        "motionCharacter": {
          "type": "string",
          "minLength": 1
        },
        "glowUsage": {
          "type": "string",
          "minLength": 1
        },
        "surfaceStyle": {
          "type": "string",
          "minLength": 1
        },
        "accentStrategy": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
