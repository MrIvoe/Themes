{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/MrIvoe/Themes/schema/semantic.schema.json",
  "title": "Semantic Theme Mapping",
  "type": "object",
  "minProperties": 1,
  "additionalProperties": {
    "$ref": "#/$defs/semanticNode"
  },
  "$defs": {
    "semanticNode": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*(?:\\.[a-z][a-z0-9_]*)+$"
        },
        {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "$ref": "#/$defs/semanticNode"
          }
        }
      ]
    }
  }
}
